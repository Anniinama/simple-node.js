<h1> {{title}}</h1>

{{#each products}}
<div class="card">

    <p>Product name: {{this.name}}</p>
    <p>Included pieces: {{this.pieces}}</p>
    <p>Price: {{this.price}}</p>
    <p>Product category: {{this.category}}</p>
    <p>Main color of the product: {{this.colorOfTheFlower}}</p>
    <p>Availability in stock:   
        {{#if this.inStock}}
        Yes
        {{else}}
        No
        {{/if}}
    </p>

</div>
{{/each}}


<p>Total products:
{{this.length}}</p>

